# Firebase web config — copy to .env.local and fill in from the Firebase console
# (Project settings → General → Your apps → Web app → SDK setup & configuration).
# Online multiplayer activates only when these are present; otherwise the app
# runs in pass-and-play mode.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# PostHog (free tier) — custom event analytics (game_started / game_finished).
# Project API key + host from PostHog → Settings → Project. US cloud host shown;
# use https://eu.i.posthog.com if you picked the EU region.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
