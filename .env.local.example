# Firebase web config — copy to .env.local and fill in from the Firebase console
# (Project settings → General → Your apps → Web app → SDK setup & configuration).
# Online multiplayer activates only when these are present; otherwise the app
# runs in pass-and-play mode.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
